  "max_pending": 20,
  "dedup_similarity": 0.5,
  "max_tokens_per_run": 150000,
  "max_usd_per_day": 2.0,
  "sources": [
    "claude_code"
  ],
  "mining_backend": "claude_cli",
  "mining_command": null,
  "codex_sessions_dir": null,
  "jsonl_dirs": [],
  "redact_secrets": true,
  "ack_command_backend": false
