{
  "model": "sonnet",
  "model_fallbacks": [
    "haiku"
  ],
  "scope": "all",
  "min_confidence": 0.55,
  "min_utility": 0.4,
  "min_segment_chars": 700,
  "max_segment_chars": 22000,
  "max_segments_per_run": 8,
  "mine_timeout_sec": 240,
  "exclude_projects": [],
